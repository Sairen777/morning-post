# Copy this file to .env.production.local; Bun scripts load it explicitly.
# SERVER_HOSTNAME precedence: an explicit server override wins, then this value,
# then the built-in default 127.0.0.1.
SERVER_HOSTNAME=127.0.0.1

DATABASE_URL=postgres://morningpost:morningpost@localhost:5432/morningpost
TEST_DATABASE_URL=postgres://morningpost:morningpost@localhost:5432/morningpost_test
E2E_DATABASE_URL=
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_SECONDS=20
DB_CONNECT_TIMEOUT_SECONDS=30
DB_SSL_MODE=disable
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
TRUSTED_PROXY_COUNT=0
MAX_REQUEST_BODY_BYTES=1048576
SUMMARIZER_MODEL=deepseek-v4-pro
SUMMARIZER_BASE_URL=https://api.deepseek.com
SUMMARIZER_API_KEY=
VISION_MODEL=gemini-2.5-flash-lite
VISION_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
VISION_API_KEY=
ALLOW_REMOTE_SUMMARIZATION=true
CONNECTOR_TIMEOUT_MS=120000
SUMMARIZER_TEXT_BYTES_PER_CHUNK=120000
SUMMARIZER_MAX_ITEMS_PER_CHUNK=50
SUMMARIZER_MAX_IMAGE_BYTES=1000000
SUMMARIZER_TIMEOUT_MS=120000
DIGEST_PROGRESS_LOGGING=false
SUMMARIZATION_CONCURRENCY=2
MEDIA_TTL_MS=604800000
MEDIA_QUOTA_BYTES=524288000
DIGEST_RUN_STALE_AFTER_MS=900000
SCHEDULER_LEASE_MS=90000
