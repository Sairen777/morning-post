{
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/web"
  ],
  "engines": {
    "bun": "1.3.14"
  },
  "scripts": {
    "dev:cli": "bun --env-file=.env.production.local --watch src/cli/run-once.ts",
    "db:generate": "bun --env-file=.env.production.local drizzle-kit generate",
    "db:migrate": "bun --env-file=.env.production.local src/db/migrate.ts",
    "db:cleanup": "bun --env-file=.env.production.local src/db/cleanup.ts",
    "dev:api": "bun --env-file=.env.production.local --watch src/server/main.ts",
    "start": "bun --env-file=.env.production.local src/server/main.ts",
    "e2e:api": "bun --env-file=.env.production.local scripts/e2e-environment.ts start-api",
    "e2e:db:cleanup": "bun --env-file=.env.production.local scripts/e2e-environment.ts cleanup",
    "test": "bun --env-file=.env.production.local test tests",
    "capture-fixtures": "bun --env-file=.env.production.local scripts/capture-fixtures.ts",
    "typecheck:runtime": "tsc --project tsconfig.runtime.json",
    "typecheck": "tsc --project tsconfig.json && bun run web:typecheck",
    "web:dev": "bun run --cwd apps/web dev",
    "web:e2e:server": "bun run --cwd apps/web e2e:server",
    "web:build": "bun run --cwd apps/web build",
    "web:preview": "bun run --cwd apps/web preview",
    "web:typecheck": "bun run --cwd apps/web typecheck",
    "web:test": "bun run --cwd apps/web test",
    "web:test:watch": "bun run --cwd apps/web test:watch",
    "web:e2e": "bun run --cwd apps/web e2e"
  },
  "dependencies": {
    "croner": "10.0.1",
    "drizzle-orm": "0.44.7",
    "hash-wasm": "4.12.0",
    "hono": "4.12.19",
    "html-to-text": "10.0.0",
    "ipaddr.js": "2.4.0",
    "jsonrepair": "3.14.0",
    "postgres": "3.4.9",
    "qrcode-terminal": "0.12.0",
    "sharp": "0.33.5",
    "telegram": "2.26.22",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/html-to-text": "9.0.4",
    "@types/node": "22.20.0",
    "@types/qrcode-terminal": "0.12.2",
    "drizzle-kit": "0.31.10",
    "typescript": "6.0.3"
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ]
}
