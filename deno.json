{
  "imports": {
    "@hono/hono": "jsr:@hono/hono"
  },
  "tasks": {
    "dev": "deno run --watch --env-file=.env.production.local --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi src/index.ts",
    "start": "deno run --env-file=.env.production.local --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi src/index.ts",
    "test": "deno test --allow-read --allow-write --allow-net --allow-env tests/",
    "capture-fixtures": "deno run --env-file=.env.production.local --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi scripts/capture-fixtures.ts"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "target": "ES2021",
    "strict": true,
    "skipLibCheck": true
  },
  "allowScripts": {
    "allow": ["npm:sharp"],
    "deny": [
      "npm:bufferutil@4.1.0",
      "npm:core-js@2.6.12",
      "npm:es5-ext@0.10.64",
      "npm:utf-8-validate@5.0.10"
    ]
  }
}
