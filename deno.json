{
  "imports": {
    "@hono/hono": "jsr:@hono/hono",
    "input": "npm:input@1.0.1",
    "qrcode-terminal": "npm:qrcode-terminal@0.12.0",
    "jsonrepair": "npm:jsonrepair@3.14.0",
    "telegram": "npm:telegram@2.26.22",
    "sharp": "npm:sharp@0.33.5",
    "drizzle-orm": "npm:drizzle-orm@0.44.7",
    "postgres": "npm:postgres@3.4.5",
    "zod": "npm:zod@3.24.4",
    "hash-wasm": "npm:hash-wasm@4.12.0",
    "@std/assert": "jsr:@std/assert@1.0.19",
    "ipaddr.js": "npm:ipaddr.js@2.4.0",
    "html-to-text": "npm:html-to-text@10.0.0",
    "@std/encoding": "jsr:@std/encoding@1.0.7"
  },
  "permissions": {
    "api": {
      "net": true,
      "env": [
        "DATABASE_URL",
        "PGTARGETSESSIONATTRS",
        "NODE_ENV",
        "PORT",
        "SERVER_HOSTNAME",
        "CREDENTIAL_MASTER_KEY",
        "TELEGRAM_API_ID",
        "TELEGRAM_API_HASH",
        "TELEGRAM_SESSION",
        "SUMMARIZER_API_KEY",
        "SUMMARIZER_MODEL",
        "SUMMARIZER_BASE_URL",
        "VISION_MODEL",
        "VISION_BASE_URL",
        "VISION_API_KEY",
        "ALLOWED_ORIGINS",
        "TRUSTED_PROXY_COUNT",
        "MAX_REQUEST_BODY_BYTES",
        "DB_POOL_MAX",
        "DB_IDLE_TIMEOUT_SECONDS",
        "DB_CONNECT_TIMEOUT_SECONDS",
        "DB_SSL_MODE",
        "ALLOW_REMOTE_SUMMARIZATION",
        "CONNECTOR_TIMEOUT_MS",
        "SUMMARIZER_TEXT_BYTES_PER_CHUNK",
        "SUMMARIZER_MAX_ITEMS_PER_CHUNK",
        "SUMMARIZER_MAX_IMAGE_BYTES",
        "SUMMARIZER_TIMEOUT_MS",
        "SUMMARIZATION_CONCURRENCY",
        "MEDIA_TTL_MS",
        "MEDIA_QUOTA_BYTES",
        "DIGEST_RUN_STALE_AFTER_MS",
        "SCHEDULER_LEASE_MS"
      ],
      "read": [
        "./src",
        "./apps",
        "./scripts",
        "./drizzle",
        "./node_modules",
        "./telegram_media",
        "./substack_media",
        "./youtube_media",
        "./reddit_media",
        "./x_media",
        "./rss_media",
        "./media",
        "./.debug_logs",
        "./deno.json",
        "./package.json",
        "./drizzle.config.ts",
        "./tsconfig.json",
        "./.env",
        "./.env.production.local"
      ],
      "write": [
        "./telegram_media",
        "./substack_media",
        "./youtube_media",
        "./reddit_media",
        "./x_media",
        "./rss_media",
        "./media",
        "./.debug_logs"
      ],
      "ffi": ["./node_modules"]
    },
    "migrate": {
      "net": ["127.0.0.1:5432", "localhost:5432"],
      "env": [
        "DATABASE_URL",
        "DB_IDLE_TIMEOUT_SECONDS",
        "DB_CONNECT_TIMEOUT_SECONDS",
        "DB_SSL_MODE"
      ],
      "read": [
        "./src",
        "./drizzle",
        "./node_modules",
        "./deno.json",
        "./package.json",
        "./drizzle.config.ts",
        "./.env",
        "./.env.production.local"
      ]
    },
    "databaseCleanup": {
      "net": ["127.0.0.1", "localhost"],
      "env": ["DATABASE_URL"],
      "read": [
        "./src",
        "./node_modules",
        "./deno.json",
        "./package.json",
        "./.env.production.local"
      ]
    },
    "test": {
      "net": [
        "127.0.0.1:3000",
        "127.0.0.1:3100",
        "127.0.0.1:5432",
        "localhost:5432",
        "localhost:1234",
        "127.0.0.1:1234",
        "generativelanguage.googleapis.com"
      ],
      "env": true,
      "read": [
        "./src",
        "./apps",
        "./scripts",
        "./tests",
        "./media",
        "./telegram_media",
        "./substack_media",
        "./youtube_media",
        "./reddit_media",
        "./x_media",
        "./rss_media",
        "./drizzle",
        "./node_modules",
        "./deno.json",
        "./package.json",
        "./drizzle.config.ts",
        "./tsconfig.json",
        "./.env",
        "./.env.production.local",
        "./.test-data",
        "./.debug_logs"
      ],
      "write": [
        "./telegram_media",
        "./substack_media",
        "./youtube_media",
        "./reddit_media",
        "./x_media",
        "./rss_media",
        "./media",
        "./.debug_logs",
        "./.test-data"
      ],
      "ffi": ["./node_modules"]
    },
    "cli": {
      "net": true,
      "env": [
        "DATABASE_URL",
        "PGTARGETSESSIONATTRS",
        "NODE_ENV",
        "PORT",
        "CREDENTIAL_MASTER_KEY",
        "TELEGRAM_API_ID",
        "TELEGRAM_API_HASH",
        "TELEGRAM_SESSION",
        "SUMMARIZER_API_KEY",
        "SUMMARIZER_MODEL",
        "SUMMARIZER_BASE_URL",
        "VISION_MODEL",
        "VISION_BASE_URL",
        "VISION_API_KEY",
        "ALLOW_REMOTE_SUMMARIZATION",
        "CONNECTOR_TIMEOUT_MS",
        "SUMMARIZER_TEXT_BYTES_PER_CHUNK",
        "SUMMARIZER_MAX_ITEMS_PER_CHUNK",
        "SUMMARIZER_MAX_IMAGE_BYTES",
        "SUMMARIZER_TIMEOUT_MS",
        "SUMMARIZATION_CONCURRENCY",
        "MEDIA_TTL_MS",
        "MEDIA_QUOTA_BYTES",
        "DIGEST_RUN_STALE_AFTER_MS",
        "SCHEDULER_LEASE_MS"
      ],
      "read": [
        "./src",
        "./apps",
        "./scripts",
        "./drizzle",
        "./node_modules",
        "./telegram_media",
        "./substack_media",
        "./youtube_media",
        "./reddit_media",
        "./x_media",
        "./rss_media",
        "./media",
        "./.debug_logs",
        "./deno.json",
        "./package.json",
        "./tsconfig.json",
        "./.env",
        "./.env.production.local"
      ],
      "write": [
        "./telegram_media",
        "./substack_media",
        "./youtube_media",
        "./reddit_media",
        "./x_media",
        "./rss_media",
        "./media",
        "./.debug_logs"
      ],
      "ffi": ["./node_modules"]
    },
    "generate": {
      "net": ["127.0.0.1:5432", "localhost:5432"],
      "env": ["DATABASE_URL", "PGTARGETSESSIONATTRS"],
      "read": [
        "./src",
        "./drizzle",
        "./node_modules",
        "./deno.json",
        "./package.json",
        "./drizzle.config.ts",
        "./.env",
        "./.env.production.local"
      ],
      "write": ["./drizzle"]
    }
  },
  "tasks": {
    "dev:cli": "deno run -P=cli --watch --env-file=.env.production.local src/cli/run-once.ts",
    "db:generate": "deno run -P=generate --env-file=.env.production.local npm:drizzle-kit@0.31 generate",
    "db:migrate": "deno run -P=migrate --env-file=.env.production.local src/db/migrate.ts",
    "db:cleanup": "deno run -P=databaseCleanup --env-file=.env.production.local src/db/cleanup.ts",
    "dev:api": "deno run -P=api --unstable-cron --unstable-no-legacy-abort --watch --env-file=.env.production.local src/server/main.ts",
    "start": "deno run -P=api --unstable-cron --unstable-no-legacy-abort --env-file=.env.production.local src/server/main.ts",
    "e2e:api": "deno run -P=test --unstable-cron --unstable-no-legacy-abort --env-file=.env.production.local scripts/e2e-environment.ts start-api",
    "e2e:db:cleanup": "deno run -P=test --env-file=.env.production.local scripts/e2e-environment.ts cleanup",
    "test": "deno test -P=test --env-file=.env.production.local tests/",
    "capture-fixtures": "deno run -P=cli --allow-write=./tests/fixtures --env-file=.env.production.local scripts/capture-fixtures.ts"
  },
  "lint": {
    "rules": {
      "include": ["curly"]
    }
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "target": "ES2021",
    "strict": true,
    "skipLibCheck": true
  },
  "allowScripts": {
    "allow": [
      "npm:sharp@0.33.5",
      "npm:bufferutil@4.1.0",
      "npm:core-js@2.6.12",
      "npm:es5-ext@0.10.64",
      "npm:utf-8-validate@5.0.10"
    ]
  }
}
