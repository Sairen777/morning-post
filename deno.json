{
  "imports": {
    "@hono/hono": "jsr:@hono/hono",
    "input": "npm:input@1.0.1",
    "qrcode-terminal": "npm:qrcode-terminal@0.12.0",
    "jsonrepair": "npm:jsonrepair@3.14.0",
    "telegram": "npm:telegram@2.26.22",
    "sharp": "npm:sharp@0.33.5"
  },
  "tasks": {
    "dev:cli": "deno run --watch --env-file=.env.production.local --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi src/index.ts",
    "dev:api": "deno run --watch --env-file=.env.production.local --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi src/index.ts",
    "start": "deno run --env-file=.env.production.local --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi src/index.ts",
    "test": "deno test --allow-read --allow-write --allow-net --allow-env tests/",
    "capture-fixtures": "deno run --env-file=.env.production.local --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi scripts/capture-fixtures.ts"
  },
  "lint": {
    "rules": {
      "include": ["curly"]
    }
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "target": "ES2021",
    "strict": true,
    "skipLibCheck": true
  },
  "allowScripts": {
    "allow": [
      "npm:sharp@0.33.5",
      "npm:bufferutil@4.1.0",
      "npm:core-js@2.6.12",
      "npm:es5-ext@0.10.64",
      "npm:utf-8-validate@5.0.10"
    ]
  }
}
