{
  "imports": {
    "@hono/hono": "jsr:@hono/hono",
    "input": "npm:input@1.0.1",
    "qrcode-terminal": "npm:qrcode-terminal@0.12.0",
    "jsonrepair": "npm:jsonrepair@3.14.0",
    "telegram": "npm:telegram@2.26.22",
    "sharp": "npm:sharp@0.33.5",
    "drizzle-orm": "npm:drizzle-orm@0.44.7",
    "postgres": "npm:postgres@3.4.5",
    "zod": "npm:zod@3.24.4",
    "hash-wasm": "npm:hash-wasm@4.12.0",
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@std/encoding": "jsr:@std/encoding@1.0.7"
  },
  "tasks": {
    "dev:cli": "deno run --watch --env-file=.env.production.local --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi src/cli/run-once.ts",
    "db:generate": "deno run -A npm:drizzle-kit@0.31 generate",
    "db:migrate": "deno run --allow-net --allow-env --allow-read src/db/migrate.ts",
    "dev:api": "deno run --watch --env-file=.env.production.local --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi src/server/main.ts",
    "start": "deno run --env-file=.env.production.local --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi src/server/main.ts",
    "test": "deno test --allow-read --allow-write --allow-net --allow-env tests/",
    "capture-fixtures": "deno run --env-file=.env.production.local --allow-net --allow-env --allow-read --allow-write --allow-sys --allow-ffi scripts/capture-fixtures.ts"
  },
  "lint": {
    "rules": {
      "include": ["curly"]
    }
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "target": "ES2021",
    "strict": true,
    "skipLibCheck": true
  },
  "allowScripts": {
    "allow": [
      "npm:sharp@0.33.5",
      "npm:bufferutil@4.1.0",
      "npm:core-js@2.6.12",
      "npm:es5-ext@0.10.64",
      "npm:utf-8-validate@5.0.10"
    ]
  }
}
